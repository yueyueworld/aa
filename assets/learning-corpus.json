[
  { "id": "transport-001", "scene": "transport", "en": "I need help.", "zh": "我需要帮助。" },
  { "id": "transport-002", "scene": "transport", "en": "How to get there?", "zh": "怎么去那里？" },
  { "id": "transport-003", "scene": "transport", "en": "Is this the right place?", "zh": "是在这里坐车吗？" },
  { "id": "transport-004", "scene": "transport", "en": "Which line goes to Hyde Park?", "zh": "去海德公园要坐哪条线路？" },
  { "id": "transport-005", "scene": "transport", "en": "Is this the right platform?", "zh": "这是正确的站台吗？" },
  { "id": "transport-006", "scene": "transport", "en": "How much is the ticket?", "zh": "车票多少钱？" },
  { "id": "transport-007", "scene": "transport", "en": "Which exit to take?", "zh": "该走哪个出口？" },
  { "id": "transport-008", "scene": "transport", "en": "I want some water.", "zh": "我想要点水。" },
  { "id": "transport-009", "scene": "transport", "en": "Thank you very much.", "zh": "非常感谢你。" },
  { "id": "transport-010", "scene": "transport", "en": "Which exit should I take?", "zh": "我该走哪个出口？" },
  { "id": "transport-011", "scene": "transport", "en": "Is there a shop near here?", "zh": "这附近有商店吗？" },
  { "id": "transport-012", "scene": "transport", "en": "Have a nice day!", "zh": "祝你过得愉快！" },
  { "id": "transport-013", "scene": "transport", "en": "I want to go back.", "zh": "我想要回去。" },
  { "id": "transport-014", "scene": "transport", "en": "Can you help me?", "zh": "你能帮帮我吗？" },
  { "id": "transport-015", "scene": "transport", "en": "Have a safe trip.", "zh": "祝你一路平安。" },
  { "id": "transport-016", "scene": "transport", "en": "I want to go back to my hotel.", "zh": "我想回我的酒店。" },
  { "id": "transport-017", "scene": "transport", "en": "It's near King's Cross Station.", "zh": "它在国王十字车站附近。" },
  { "id": "transport-018", "scene": "transport", "en": "Thanks for your help!", "zh": "谢谢你的帮助！" },
  { "id": "hotel-001", "scene": "hotel", "en": "Good evening! Welcome to our hotel.", "zh": "晚上好！欢迎来到我们的酒店。" },
  { "id": "hotel-002", "scene": "hotel", "en": "I have a booking.", "zh": "我有预订。" },
  { "id": "hotel-003", "scene": "hotel", "en": "My name is Li Ming.", "zh": "我的名字是李明。" },
  { "id": "hotel-004", "scene": "hotel", "en": "Is that right?", "zh": "对吗？" },
  { "id": "hotel-005", "scene": "hotel", "en": "What time is breakfast?", "zh": "早餐几点供应？" },
  { "id": "hotel-006", "scene": "hotel", "en": "Here is your key.", "zh": "这是你的房卡。" },
  { "id": "hotel-007", "scene": "hotel", "en": "Where is the lift?", "zh": "电梯在哪里？" },
  { "id": "hotel-008", "scene": "hotel", "en": "Good morning! Did you sleep well?", "zh": "早上好！你睡得好吗？" },
  { "id": "hotel-009", "scene": "hotel", "en": "I slept well.", "zh": "我睡得很好。" },
  { "id": "hotel-010", "scene": "hotel", "en": "I want to have breakfast now.", "zh": "我现在想用早餐。" },
  { "id": "hotel-011", "scene": "hotel", "en": "Full English breakfast or something simple?", "zh": "要全英式早餐还是简单点的餐食？" },
  { "id": "hotel-012", "scene": "hotel", "en": "Full English breakfast, please.", "zh": "麻烦给我一份全英式早餐。" },
  { "id": "hotel-013", "scene": "hotel", "en": "And a cup of coffee.", "zh": "再加一杯咖啡。" },
  { "id": "hotel-014", "scene": "hotel", "en": "You can sit anywhere.", "zh": "你可以随便坐。" },
  { "id": "hotel-015", "scene": "hotel", "en": "I'll sit over there.", "zh": "我会坐在那边。" },
  { "id": "hotel-016", "scene": "hotel", "en": "Are you leaving today?", "zh": "你今天要离店吗？" },
  { "id": "hotel-017", "scene": "hotel", "en": "Did you enjoy your stay?", "zh": "你住得还满意吗？" },
  { "id": "hotel-018", "scene": "hotel", "en": "It was great.", "zh": "体验非常好。" },
  { "id": "hotel-019", "scene": "hotel", "en": "I want to pay now.", "zh": "我现在想结账。" },
  { "id": "hotel-020", "scene": "hotel", "en": "Here is your bill.", "zh": "这是你的账单。" },
  { "id": "hotel-021", "scene": "hotel", "en": "Card or cash?", "zh": "刷卡还是付现金？" },
  { "id": "hotel-022", "scene": "hotel", "en": "By card, please.", "zh": "麻烦刷卡支付。" },
  { "id": "hotel-023", "scene": "hotel", "en": "All done!", "zh": "办理完成啦！" },
  { "id": "hotel-024", "scene": "hotel", "en": "Come back again soon!", "zh": "欢迎下次再来！" },
  { "id": "hotel-025", "scene": "hotel", "en": "Thank you for everything.", "zh": "谢谢你所做的一切。" },
  { "id": "restaurant-001", "scene": "restaurant", "en": "Good afternoon! Do you have a booking?", "zh": "下午好！你有预订吗？" },
  { "id": "restaurant-002", "scene": "restaurant", "en": "Is there a table for one?", "zh": "有单人位吗？" },
  { "id": "restaurant-003", "scene": "restaurant", "en": "This way please.", "zh": "这边请。" },
  { "id": "restaurant-004", "scene": "restaurant", "en": "Would you like to see the menu?", "zh": "你需要看一下菜单吗？" },
  { "id": "restaurant-005", "scene": "restaurant", "en": "I want the classic afternoon tea, please.", "zh": "麻烦给我一份经典英式下午茶。" },
  { "id": "restaurant-006", "scene": "restaurant", "en": "Tea or coffee with it?", "zh": "需要配茶还是咖啡？" },
  { "id": "restaurant-007", "scene": "restaurant", "en": "Tea with milk, please.", "zh": "麻烦给我加奶的红茶。" },
  { "id": "restaurant-008", "scene": "restaurant", "en": "Here is your tea and food.", "zh": "这是你的茶和餐点。" },
  { "id": "restaurant-009", "scene": "restaurant", "en": "Enjoy!", "zh": "请慢用！" },
  { "id": "restaurant-010", "scene": "restaurant", "en": "What should I eat first?", "zh": "我应该先吃什么？" },
  { "id": "restaurant-011", "scene": "restaurant", "en": "First sandwiches, then scones, then sweets.", "zh": "先吃三明治，然后是司康饼，最后是甜点。" },
  { "id": "restaurant-012", "scene": "restaurant", "en": "How do I eat the scone?", "zh": "司康饼要怎么吃？" },
  { "id": "restaurant-013", "scene": "restaurant", "en": "Cut it open, add cream first, then jam.", "zh": "把它切开，先加奶油，再加果酱。" },
  { "id": "restaurant-014", "scene": "restaurant", "en": "That's British style!", "zh": "这是英式吃法！" },
  { "id": "restaurant-015", "scene": "restaurant", "en": "That's fun!", "zh": "这太有趣了！" },
  { "id": "restaurant-016", "scene": "restaurant", "en": "I'll try it.", "zh": "我会试试看的。" },
  { "id": "restaurant-017", "scene": "restaurant", "en": "Did you enjoy your afternoon tea?", "zh": "你喜欢你的下午茶吗？" },
  { "id": "restaurant-018", "scene": "restaurant", "en": "I loved it!", "zh": "我太喜欢了！" },
  { "id": "restaurant-019", "scene": "restaurant", "en": "Can I have another cup of tea?", "zh": "我能再要一杯茶吗？" },
  { "id": "restaurant-020", "scene": "restaurant", "en": "More hot water and milk too?", "zh": "还要加热水和牛奶吗？" },
  { "id": "restaurant-021", "scene": "restaurant", "en": "Yes, please.", "zh": "好的，麻烦了。" },
  { "id": "restaurant-022", "scene": "restaurant", "en": "Here is your bill.", "zh": "这是你的账单。" },
  { "id": "restaurant-023", "scene": "restaurant", "en": "Have a nice day!", "zh": "祝你过得愉快！" },
  { "id": "restaurant-024", "scene": "restaurant", "en": "Here is the money.", "zh": "给你钱。" },
  { "id": "museum-001", "scene": "museum", "en": "Hello! Welcome to the British Museum.", "zh": "你好！欢迎来到大英博物馆。" },
  { "id": "museum-002", "scene": "museum", "en": "First time here?", "zh": "是第一次来吗？" },
  { "id": "museum-003", "scene": "museum", "en": "I want to see the most famous things first.", "zh": "我想先看最有名的展品。" },
  { "id": "museum-004", "scene": "museum", "en": "Then you must see the Rosetta Stone!", "zh": "那你一定要看罗塞塔石碑！" },
  { "id": "museum-005", "scene": "museum", "en": "It's in the Egyptian room.", "zh": "它在埃及展厅。" },
  { "id": "museum-006", "scene": "museum", "en": "Where is the Egyptian room?", "zh": "埃及展厅在哪里？" },
  { "id": "museum-007", "scene": "museum", "en": "Go straight, turn left.", "zh": "直走，然后左转。" },
  { "id": "museum-008", "scene": "museum", "en": "You'll see the sign.", "zh": "你会看到指示牌。" },
  { "id": "museum-009", "scene": "museum", "en": "It's free!", "zh": "这里是免费开放的！" },
  { "id": "museum-010", "scene": "museum", "en": "I'll go there now.", "zh": "我现在就过去。" },
  { "id": "museum-011", "scene": "museum", "en": "Did you find the Rosetta Stone?", "zh": "你找到罗塞塔石碑了吗？" },
  { "id": "museum-012", "scene": "museum", "en": "It's amazing, right?", "zh": "它很震撼，对吗？" },
  { "id": "museum-013", "scene": "museum", "en": "It's amazing!", "zh": "它太震撼了！" },
  { "id": "museum-014", "scene": "museum", "en": "Why is it so important?", "zh": "它为什么这么重要？" },
  { "id": "museum-015", "scene": "museum", "en": "Because it helped us read ancient Egyptian writing!", "zh": "因为它帮我们读懂了古埃及的文字！" },
  { "id": "museum-016", "scene": "museum", "en": "What else should I see?", "zh": "我还应该看些什么？" },
  { "id": "museum-017", "scene": "museum", "en": "You can also see the Parthenon Marbles.", "zh": "你还可以去看帕特农神庙雕塑。" },
  { "id": "museum-018", "scene": "museum", "en": "They're in the Greek room.", "zh": "它们在希腊展厅。" },
  { "id": "museum-019", "scene": "museum", "en": "I'll go there next.", "zh": "我接下来就去那里。" },
  { "id": "museum-020", "scene": "museum", "en": "How was your visit?", "zh": "你的参观体验怎么样？" },
  { "id": "museum-021", "scene": "museum", "en": "Did you see everything you wanted?", "zh": "你看到所有想看的东西了吗？" },
  { "id": "museum-022", "scene": "museum", "en": "It was great!", "zh": "体验太棒了！" },
  { "id": "museum-023", "scene": "museum", "en": "I bought some gifts too.", "zh": "我还买了一些纪念品。" },
  { "id": "museum-024", "scene": "museum", "en": "The gift shop has many good things.", "zh": "礼品店有很多不错的东西。" },
  { "id": "museum-025", "scene": "museum", "en": "Will you come back?", "zh": "你还会再来吗？" },
  { "id": "museum-026", "scene": "museum", "en": "Yes, I hope to come back again.", "zh": "会的，我希望能再来一次。" },
  { "id": "museum-027", "scene": "museum", "en": "We'll be here!", "zh": "我们一直都在！" },
  { "id": "museum-028", "scene": "museum", "en": "Have fun in London!", "zh": "祝你在伦敦玩得开心！" }
]